\ProvidesPackage{lmedoc/packages}

% ++ use \toprule,\midrule and \bottomrule in tables; no \hline or vertical columns
\RequirePackage{booktabs}
\RequirePackage{xspace}
\RequirePackage{amsmath,amssymb}
\RequirePackage{mathtools}
\RequirePackage{bm}

% Color
\RequirePackage[usenames,dvipsnames,table]{xcolor}
\definecolor{faublue}{RGB}{0,51,102}

% Units
\RequirePackage[binary-units,abbreviations]{siunitx}
\sisetup{mode=text}

% Lists
\RequirePackage[inline]{enumitem}
\setlist*[enumerate]{label=(\arabic*)}

% No widows
\RequirePackage[all]{nowidow}

% TikZ
\RequirePackage{tikz}

% URL
\RequirePackage[hyphens]{url}

% Biblatex (biber backend, trad-alpha style)
\RequirePackage[backend=biber, bibencoding=utf8, giveninits=true,
maxbibnames=99,
maxalphanames=1, minalphanames=1,
style=trad-alpha, backref=true]{biblatex}
\DefineBibliographyStrings{english}{%
  backrefpage  = {cited on p\onedot},
  backrefpages = {cited on pp\onedot},
}

% References
\RequirePackage{varioref}
\renewcommand\reftextfaraway[1]{(p.\,\pageref{#1})}

% Hyperref
\RequirePackage{hyperref}
\hypersetup{
  colorlinks      = true,
  linkcolor       = faublue,
  urlcolor        = magenta,
  citecolor       = faublue,
  plainpages      = false,
  hypertexnames   = true,
  linktocpage     = true,
  bookmarksopen   = true,
  bookmarksnumbered = true,
  bookmarksopenlevel = 0,
}
\RequirePackage[all]{hypcap}

% Cleveref (after hyperref)
\RequirePackage[noabbrev,capitalise,nameinlink]{cleveref}

% Captions / subcaptions
\RequirePackage{caption}
\RequirePackage{subcaption}
\captionsetup[table]{position=top}
\captionsetup[figure]{position=bottom}
\captionsetup[subtable]{position=bottom}
\captionsetup{subrefformat=parens}

% Glossaries
\RequirePackage[abbreviations,shortcuts=true]{glossaries-extra}
\setabbreviationstyle{long-short}
