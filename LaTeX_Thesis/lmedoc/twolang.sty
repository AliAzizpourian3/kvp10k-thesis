%% PATCH: replaced obsolete `german.sty` with `babel` (ngerman + english).
%% The old `german.sty` is no longer available in TeX Live 2025 and caused a
%% recursive \languagename loop leading to "TeX capacity exceeded [input stack
%% size=10000]" at babel-english/english.ldf line 47.
%%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{lmedoc/twolang}
         [2000/02/19 v1.01-babel SUB Package (LME, patched)]

%% Use babel instead of the obsolete german.sty
\RequirePackage[ngerman,english]{babel}

\DeclareOption{german}{\selectlanguage{ngerman}}
\DeclareOption{english}{\selectlanguage{english}}
\ProcessOptions

\makeatletter
\long\def\twolang#1#2{%
  \ifnum\language=\l@ngerman
    #1%
  \else
    #2%
  \fi
}
\makeatother

\addto\captionsenglish{%
  \def\abbreviationsname{List of Abbreviations}%
}
\addto\captionsngerman{%
  \def\prefacename{Vorwort}%
  \def\refname{Literatur}%
  \def\abstractname{Zusammenfassung}%
  \def\bibname{Literaturverzeichnis}%
  \def\chaptername{Kapitel}%
  \def\appendixname{Anhang}%
  \def\contentsname{Inhaltsverzeichnis}%
  \def\figurename{Bild}%
  \def\listfigurename{Verzeichnis der Bilder}%
  \def\listtablename{Verzeichnis der Tabellen}%
  \def\indexname{Index}%
  \def\tablename{Tabelle}%
  \def\partname{Teil}%
  \def\enclname{Anlage(n):}%
  \def\ccname{Verteiler:}%
  \def\headtoname{An}%
  \def\pagename{Seite}%
  \def\seename{siehe}%
  \def\alsoname{siehe auch}%
  \def\abbreviationsname{Abk\"urzungsverzeichnis}%
}

\endinput
%%
%% End of file `twolang.sty'.
